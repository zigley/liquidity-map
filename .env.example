# Robinhood credentials (required for auto-trade)
RH_USERNAME=your_email@example.com
RH_PASSWORD=your_password

# Auto-trade settings (dry-run ON by default — no real orders)
AUTO_TRADE_DRY_RUN=true
AUTO_TRADE_AMOUNT_USD=100
AUTO_TRADE_MIN_STRENGTH=2
AUTO_TRADE_MAX_DAILY=5
AUTO_TRADE_REQUIRE_LIQUID_SPREAD=true